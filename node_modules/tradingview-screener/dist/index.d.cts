type FieldFormat = 'currency' | 'percent' | 'float' | 'round' | 'number_group' | 'text' | 'date' | 'bool' | 'rating' | 'recommendation' | 'computed_recommendation' | 'missing';
interface FieldMetadata {
    label: string;
    fieldName: string;
    format: FieldFormat;
    interval: boolean;
    historical: boolean;
}
interface FilterDict {
    left: string;
    operation: string;
    right?: any;
}
interface SortConfig {
    sortBy: string;
    sortOrder: 'asc' | 'desc';
}
interface SymbolsConfig {
    query?: {
        types?: string[];
    };
    tickers?: string[];
}
interface QueryPayload {
    filter: FilterDict[];
    options: Record<string, any>;
    symbols: SymbolsConfig;
    sort?: SortConfig;
    range: [number, number];
    columns: string[];
}
interface ScreenerRow {
    symbol?: string;
    [key: string]: any;
}
interface ScreenerResult<T = ScreenerRow> {
    data: T[];
    totalCount: number;
}
interface StreamOptions {
    interval?: number;
    maxIterations?: number;
}
interface ApiResponse {
    data: any[];
    totalCount: number;
}
interface FieldSearchOptions {
    format?: FieldFormat;
    interval?: boolean;
    historical?: boolean;
}

declare class Filter {
    readonly left: string;
    readonly operation: string;
    readonly right?: any | undefined;
    constructor(left: string, operation: string, right?: any | undefined);
    toDict(): FilterDict;
    static fromDict(dict: FilterDict): Filter;
}

declare class FieldCondition {
    readonly field: BaseField;
    readonly operation: string;
    readonly value: any;
    constructor(field: BaseField, operation: string, value: any);
    private validateCondition;
    toFilter(): Filter;
    toString(): string;
}

declare class BaseField {
    readonly name: string;
    readonly metadata: FieldMetadata;
    constructor(name: string, metadata: FieldMetadata);
    get fieldName(): string;
    get label(): string;
    get format(): FieldFormat;
    get supportsInterval(): boolean;
    get supportsHistory(): boolean;
    gt(value: number): FieldCondition;
    gte(value: number): FieldCondition;
    lt(value: number): FieldCondition;
    lte(value: number): FieldCondition;
    eq(value: any): FieldCondition;
    ne(value: any): FieldCondition;
    between(min: number, max: number): FieldCondition;
    notBetween(min: number, max: number): FieldCondition;
    isin(values: any[]): FieldCondition;
    notIn(values: any[]): FieldCondition;
    match(pattern: string): FieldCondition;
    notMatch(pattern: string): FieldCondition;
    has(values: any[]): FieldCondition;
    hasNoneOf(values: any[]): FieldCondition;
    above(value: number): FieldCondition;
    below(value: number): FieldCondition;
    crosses(value: number): FieldCondition;
    crossesAbove(value: number): FieldCondition;
    crossesBelow(value: number): FieldCondition;
    toString(): string;
    static search(fields: Record<string, BaseField>, query: string, options?: FieldSearchOptions): BaseField[];
    static byFormat(fields: Record<string, BaseField>, format: FieldFormat): BaseField[];
    static technicals(fields: Record<string, BaseField>): BaseField[];
    static recommendations(fields: Record<string, BaseField>): BaseField[];
}

declare abstract class BaseScreener<TField extends typeof BaseField = any> {
    protected filters: Filter[];
    protected sort: SortConfig | null;
    protected range: [number, number];
    protected options: Record<string, any>;
    protected symbols: SymbolsConfig | null;
    protected specificFields: BaseField[] | null;
    protected abstract fieldType: TField | null;
    protected abstract url: string;
    protected abstract defaultFields: BaseField[];
    protected validateFieldType(field: BaseField): void;
    where(condition: FieldCondition): this;
    select(...fields: BaseField[]): this;
    selectAll(): this;
    sortBy(field: BaseField, ascending?: boolean): this;
    setRange(from?: number, to?: number): this;
    setIndex(...indexSymbols: string[]): this;
    protected addOption(key: string, value: any): void;
    protected buildPayload(columns: string[]): QueryPayload;
    get(printRequest?: boolean): Promise<ScreenerResult>;
    stream(options?: StreamOptions): AsyncGenerator<ScreenerResult | null>;
}

